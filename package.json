{
  "name": "fud-health-information-management-system",
  "version": "2.0.0",
  "description": "FUD HIMS — Hospital Information Management System for Federal University Dutse",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start":       "node server.js",
    "dev:server":  "node --watch server.js",
    "dev:client":  "vite",
    "dev":         "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build":       "vite build",
    "preview":     "vite preview",
    "db:init":     "psql $DATABASE_URL -f schema.sql"
  },
  "dependencies": {
    "bcryptjs":    "^2.4.3",
    "concurrently":"^8.2.2",
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.19.2",
    "jsonwebtoken":"^9.0.2",
    "lucide-react":"^0.395.0",
    "pg":          "^8.12.0",
    "react":       "^18.3.1",
    "react-dom":   "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer":         "^10.4.19",
    "postcss":              "^8.4.38",
    "tailwindcss":          "^3.4.4",
    "vite":                 "^5.3.1"
  }
}
